# Finnhub API key — required for fetch_snapshot.py
# Get one free at https://finnhub.io
FINNHUB_API_KEY=

# Grafana Cloud remote_write endpoint
# Found in: Grafana Cloud → Prometheus data source → Remote Write URL
# Format: https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
GRAFANA_REMOTE_WRITE_URL=

# Grafana Cloud Prometheus user ID (numeric)
# Found in: Grafana Cloud → Prometheus data source → Username
GRAFANA_CLOUD_PROM_USER=

# Grafana Cloud API token with MetricsPublisher role
# Create at: https://grafana.com/orgs/YOUR_ORG/api-keys
GRAFANA_CLOUD_API_KEY=
